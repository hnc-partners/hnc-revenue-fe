# Revenue MF Configuration
# Copy to .env.local and customize

# === Mock Auth (standalone dev without login) ===
VITE_MOCK_AUTH=true

# === Auth ===
VITE_AUTH_URL=https://hncms-auth.scarif-0.duckdns.org/api/auth

# === API Proxy Targets (override defaults for local backend dev) ===
# VITE_REVENUE_API_TARGET=http://localhost:3106
# VITE_REPORT_MANAGEMENT_API_TARGET=http://localhost:3107

# === Production API URLs (set in .env.production) ===
# VITE_REVENUE_API_URL=https://hncms-revenue.scarif-0.duckdns.org
# VITE_REPORT_MANAGEMENT_API_URL=https://hncms-report-management.scarif-0.duckdns.org
